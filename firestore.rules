rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow anyone to read/write API configuration
    match /api_config/{document=**} {
      allow read, write: if true;
    }

    // Allow anyone to read/write leads
    match /leads/{document=**} {
      allow read, write: if true;
    }

    // Allow anyone to read/write lead searches
    match /lead_searches/{document=**} {
      allow read, write: if true;
    }

    // Allow anyone to read/write activities
    match /lead_activities/{document=**} {
      allow read, write: if true;
    }

    // Allow anyone to read/write import metrics
    match /import_metrics/{document=**} {
      allow read, write: if true;
    }

    // Default: deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
